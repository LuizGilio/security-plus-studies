<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Security+ SY0-701 — Domínio 1: General Security Concepts</title>
  </head>
  <body>
    <outline text="Security+ SY0-701 — Domínio 1: General Security Concepts">

      <outline text="1. FUNDAMENTOS DE SEGURANÇA">

        <outline text="CIA Triad ⭐⭐⭐ [PROVA: conceito base de TODAS as questões]">
          <outline text="Também chamado de AIC Triad (evitar confusão com a CIA americana)"/>
          <outline text="C — Confidencialidade">
            <outline text="Impede acesso não autorizado a informações privadas"/>
            <outline text="Métodos">
              <outline text="Criptografia — criptografar dados em trânsito e em repouso"/>
              <outline text="Controles de Acesso — limitar quem acessa quais recursos"/>
              <outline text="Autenticação Multifator (MFA) — credenciais adicionais de login"/>
            </outline>
          </outline>
          <outline text="I — Integridade">
            <outline text="Garante que dados recebidos são idênticos aos enviados"/>
            <outline text="Métodos">
              <outline text="Hashing — impressão digital única do dado"/>
              <outline text="Assinatura Digital — hash criptografado com chave privada"/>
              <outline text="Certificados Digitais — identificam dispositivos e pessoas"/>
              <outline text="Não-Repúdio — prova irrefutável de origem do dado"/>
            </outline>
          </outline>
          <outline text="A — Disponibilidade (Availability)">
            <outline text="Sistemas acessíveis aos usuários autorizados a qualquer momento"/>
            <outline text="Métodos">
              <outline text="Redundância e Tolerância a Falhas — componentes de backup assumem se um falhar"/>
              <outline text="Patching e Atualizações — evitar exploits e garantir estabilidade"/>
            </outline>
          </outline>
        </outline>

        <outline text="AAA Framework ⭐⭐⭐ [PROVA: muito cobrado em cenários de VPN e acesso]">
          <outline text="Autenticação, Autorização e Contabilidade (Accounting)"/>
          <outline text="1. Identificação — alegar ser um usuário específico"/>
          <outline text="2. Autenticação — provar que você é quem diz ser"/>
          <outline text="3. Autorização — definir quais recursos o usuário pode acessar"/>
          <outline text="4. Contabilidade (Accounting) — registrar tudo: login, logout, dados transferidos"/>
          <outline text="Exemplo Prático: VPN">
            <outline text="Cliente → Concentrador VPN → Servidor AAA central → Servidor de arquivos"/>
            <outline text="O concentrador VPN repassa credenciais ao servidor AAA para validação"/>
          </outline>
          <outline text="Autenticação de Dispositivos">
            <outline text="Certificados digitais identificam dispositivos autorizados"/>
            <outline text="Autoridade de Certificação (CA) gerencia e assina os certificados"/>
          </outline>
          <outline text="Modelos de Autorização e Escalabilidade">
            <outline text="Autorização manual por usuário não escala"/>
            <outline text="Solução: Grupos de usuários (ex: Departamento de Envio e Recebimento)"/>
            <outline text="Adicionar usuário ao grupo concede todos os acessos necessários automaticamente"/>
          </outline>
        </outline>

      </outline>

      <outline text="2. CRIPTOGRAFIA E INTEGRIDADE DE DADOS">

        <outline text="Hashing ⭐⭐⭐ [PROVA: saber diferenciar hash de criptografia]">
          <outline text="Definição: impressão digital (fingerprint) de um dado"/>
          <outline text="Qualquer alteração mínima no dado muda completamente o hash"/>
          <outline text="Não é criptografia — hash NÃO é reversível"/>
          <outline text="Uso: verificar integridade de arquivos, senhas, certificados"/>
          <outline text="Exemplo: hash de arquivo de 8.1 MB muda completamente com 1 caractere alterado"/>
        </outline>

        <outline text="Assinaturas Digitais ⭐⭐⭐ [PROVA: entender o fluxo completo Alice-Bob]">
          <outline text="Garante: Integridade + Prova de Origem + Não-Repúdio"/>
          <outline text="Usa par de chaves: chave privada para assinar, chave pública para verificar"/>
          <outline text="Processo completo (Alice para Bob)">
            <outline text="1. Alice gera o hash do texto original"/>
            <outline text="2. Alice criptografa o hash com sua CHAVE PRIVADA — cria a Assinatura Digital"/>
            <outline text="3. Alice envia: texto plano + assinatura digital"/>
            <outline text="4. Bob descriptografa a assinatura com a CHAVE PÚBLICA de Alice — obtém hash original"/>
            <outline text="5. Bob gera novo hash do texto recebido"/>
            <outline text="6. Bob compara os dois hashes — se iguais: integridade e origem confirmadas"/>
          </outline>
          <outline text="Não-Repúdio — remetente não pode negar ter enviado (só ele tem a chave privada)"/>
        </outline>

        <outline text="Certificados Digitais ⭐⭐">
          <outline text="Identificam dispositivos, servidores e pessoas"/>
          <outline text="Emitidos e assinados por uma Autoridade de Certificação (CA)"/>
          <outline text="Usados na autenticação de dispositivos no modelo AAA"/>
        </outline>

      </outline>

      <outline text="3. CONTROLES DE SEGURANÇA ⭐⭐⭐ [PROVA: classificar exemplos na matriz Tipo x Categoria]">

        <outline text="4 Categorias de Controles">
          <outline text="Técnico — implementado via sistema (firewall, antivírus, SO)"/>
          <outline text="Gerencial — políticas e procedimentos documentados (POPs)"/>
          <outline text="Operacional — implementado por pessoas (guardas, treinamentos)"/>
          <outline text="Físico — limita acesso físico (cercas, trancas, leitores de cartão)"/>
        </outline>

        <outline text="6 Tipos de Controles">
          <outline text="Preventivo — impede o acesso antes que ocorra">
            <outline text="Técnico → Regras de firewall"/>
            <outline text="Gerencial → Políticas de onboarding"/>
            <outline text="Operacional → Guarita verificando identificação"/>
            <outline text="Físico → Fechaduras de portas"/>
          </outline>
          <outline text="Dissuasor — desencoraja sem necessariamente impedir">
            <outline text="Técnico → Splash screen com avisos de segurança"/>
            <outline text="Gerencial → Ameaça de rebaixamento ou demissão"/>
            <outline text="Operacional → Recepcionista verificando visitantes"/>
            <outline text="Físico → Sinais de aviso de acesso restrito"/>
          </outline>
          <outline text="Detetivo — identifica e alerta sobre violações ocorridas">
            <outline text="Técnico → Coleta e análise de logs do sistema"/>
            <outline text="Gerencial → Revisão de relatórios de login"/>
            <outline text="Operacional → Patrulhamento da propriedade"/>
            <outline text="Físico → Detectores de movimento"/>
          </outline>
          <outline text="Corretivo — age após o evento para reverter impactos">
            <outline text="Técnico → Restaurar backup após ransomware"/>
            <outline text="Gerencial → Políticas de alerta e notificação de incidentes"/>
            <outline text="Operacional → Contatar autoridades"/>
            <outline text="Físico → Extintor de incêndio"/>
          </outline>
          <outline text="Compensatório — alternativa quando não é possível corrigir diretamente">
            <outline text="Técnico → Regra de firewall bloqueando vulnerabilidade sem patch disponível"/>
            <outline text="Gerencial → Separação de Deveres (Separation of Duties)"/>
            <outline text="Operacional → Múltiplos seguranças simultâneos"/>
            <outline text="Físico → Gerador de energia elétrica"/>
          </outline>
          <outline text="Diretivo — orienta comportamento seguro (controle mais fraco)">
            <outline text="Técnico → Política de armazenamento em pasta criptografada"/>
            <outline text="Gerencial → Políticas e procedimentos de conformidade"/>
            <outline text="Operacional → Treinamento de políticas de segurança"/>
            <outline text="Físico → Placa 'Apenas Pessoal Autorizado'"/>
          </outline>
        </outline>

      </outline>

      <outline text="4. ARQUITETURAS MODERNAS DE SEGURANÇA">

        <outline text="Zero Trust ⭐⭐⭐ [PROVA: entender PEP, PDP e Identidade Adaptativa]">
          <outline text="Premissa: redes tradicionais são abertas por dentro após o firewall"/>
          <outline text="Princípio: nunca confiar, sempre verificar — autenticação contínua"/>
          <outline text="Aplica-se a: cada dispositivo, processo e usuário"/>
          <outline text="Planos de Operação">
            <outline text="Data Plane (Plano de Dados) — processa o tráfego de rede real"/>
            <outline text="Control Plane (Plano de Controle) — define configurações e políticas"/>
          </outline>
          <outline text="Componentes de Decisão e Imposição">
            <outline text="PEP — Ponto de Imposição de Política">
              <outline text="Atua como gatekeeper de todos os acessos"/>
              <outline text="Bloqueia ou permite com base na decisão do PDP"/>
            </outline>
            <outline text="PDP — Ponto de Decisão de Política">
              <outline text="Analisa a solicitação e decide: conceder, negar ou revogar acesso"/>
            </outline>
          </outline>
          <outline text="Identidade Adaptativa">
            <outline text="Analisa risco com base em: localização, dispositivo, relação com a organização"/>
            <outline text="Reduz superfície de ataque dinamicamente"/>
          </outline>
          <outline text="Zonas de Segurança">
            <outline text="Redes categorizadas em: confiáveis e não confiáveis"/>
            <outline text="Regras de acesso baseadas no caminho da conversa"/>
          </outline>
          <outline text="Recursos de suporte: MFA + Criptografia + Políticas rigorosas"/>
        </outline>

        <outline text="Gap Analysis (Análise de Lacunas) ⭐⭐ [PROVA: conhecer frameworks NIST e ISO]">
          <outline text="Definição: onde estamos vs. onde queremos estar em segurança"/>
          <outline text="Processo pode levar semanas, meses ou anos"/>
          <outline text="Etapas do Processo">
            <outline text="1. Estabelecer Linha de Base (Baseline)">
              <outline text="NIST SP 800-171 Rev 2 — proteção de informações não classificadas em sistemas não federais"/>
              <outline text="ISO/IEC 27001 — sistemas de gestão de segurança da informação"/>
            </outline>
            <outline text="2. Avaliar Pessoas — experiência, treinamento, conhecimento de políticas"/>
            <outline text="3. Avaliar Processos — sistemas de TI em conformidade com políticas documentadas"/>
            <outline text="4. Comparar estado atual com baseline — identificar fraquezas"/>
            <outline text="5. Criar plano para compensar fraquezas"/>
          </outline>
          <outline text="Relatório Final">
            <outline text="Resume estado atual vs. estado desejado"/>
            <outline text="Painel com cores: Verde (conforme), Amarelo (atenção), Vermelho (não conforme)"/>
            <outline text="Define caminho: tempo, dinheiro, equipamentos e controle de mudanças"/>
          </outline>
        </outline>

      </outline>

      <outline text="5. SEGURANÇA FÍSICA ⭐⭐ [PROVA: classificar cada controle como preventivo, detetivo etc.]">

        <outline text="Controle de Perímetro Externo">
          <outline text="Barricadas e Bolardos">
            <outline text="Bloqueiam veículos, permitem passagem de pessoas"/>
            <outline text="Visuais (coloridos) ou estruturais (concreto)"/>
            <outline text="Barreiras naturais: água ao redor do edifício"/>
          </outline>
          <outline text="Cercas">
            <outline text="Estabelecem perímetro físico claro"/>
            <outline text="Transparentes (visibilidade) ou opacas (privacidade)"/>
            <outline text="Arame farpado / concertina (razor wire) no topo"/>
          </outline>
        </outline>

        <outline text="Controle de Acesso ao Edifício">
          <outline text="Vestíbulos de Controle (Mantraps)">
            <outline text="Sala pequena entre exterior e interior do edifício"/>
            <outline text="Uma porta trava quando a outra abre — impede tailgating"/>
            <outline text="Equipados com leitores de cartão ou biometria"/>
          </outline>
          <outline text="Guardas de Segurança">
            <outline text="Validam entrada de funcionários e visitantes"/>
            <outline text="Two-Person Integrity — dois guardas evitam burlar políticas sozinho"/>
          </outline>
          <outline text="Crachás de Identificação">
            <outline text="Visíveis a todo momento"/>
            <outline text="Registram entrada em áreas restritas"/>
          </outline>
        </outline>

        <outline text="Monitoramento e Vigilância">
          <outline text="CCTV">
            <outline text="Substitui ou auxilia guardas físicos"/>
            <outline text="Recursos modernos: detecção de movimento, reconhecimento facial, leitura de placas"/>
            <outline text="Vídeo armazenado em ponto central"/>
          </outline>
          <outline text="Iluminação">
            <outline text="Mais luz = mais segurança"/>
            <outline text="Câmeras IR funcionam no escuro, mas iluminação é preferível"/>
            <outline text="Ângulo importa: evitar sombras e glare nas câmeras"/>
          </outline>
          <outline text="Sensores de Movimento">
            <outline text="Infravermelho (IR) — detecta radiação de calor corporal"/>
            <outline text="Pressão — detecta força (pisadas, abertura de janelas)"/>
            <outline text="Micro-ondas — monitoram grandes áreas"/>
            <outline text="Ultrassônico — reflexo de som para detectar movimento"/>
          </outline>
        </outline>

      </outline>

      <outline text="6. DECEPTION TECHNOLOGY ⭐⭐ [PROVA: diferenciar Honeypot, HoneyNet, HoneyFile e HoneyToken]">

        <outline text="Conceito Geral">
          <outline text="Criar decepção e disrupção para invasores"/>
          <outline text="Manter atacantes ocupados em sistemas falsos enquanto monitora suas técnicas"/>
          <outline text="Na maioria dos casos o invasor é um processo automatizado"/>
        </outline>

        <outline text="Honeypot">
          <outline text="Sistema falso que atrai invasores para fora dos sistemas reais de produção"/>
          <outline text="Permite observar técnicas e ferramentas usadas pelo atacante"/>
          <outline text="Corrida contínua: invasores evoluem para detectar honeypots, nós aumentamos a complexidade"/>
          <outline text="Construído com software comercial ou open source — ver projecthoney.org"/>
        </outline>

        <outline text="HoneyNet">
          <outline text="Múltiplos honeypots combinados em infraestrutura completa e crível"/>
          <outline text="Inclui: estações de trabalho, servidores, roteadores e firewalls falsos"/>
          <outline text="Mantém invasores ocupados por mais tempo"/>
        </outline>

        <outline text="HoneyFile">
          <outline text="Arquivo falso com aparência de dado sensível (ex: passwords.txt)"/>
          <outline text="Nenhum usuário legítimo deve acessá-lo"/>
          <outline text="Acesso dispara alertas automáticos para a equipe de segurança"/>
        </outline>

        <outline text="HoneyToken">
          <outline text="Dado rastreável inserido na HoneyNet — revela origem de vazamentos"/>
          <outline text="Exemplos">
            <outline text="Credenciais de API falsas em compartilhamento de nuvem pública"/>
            <outline text="Endereços de e-mail falsos monitorados na internet"/>
            <outline text="Registros de banco de dados falsos"/>
            <outline text="Cookies de navegador rastreáveis"/>
            <outline text="Pixels em páginas web"/>
          </outline>
        </outline>

      </outline>

      <outline text="7. CONEXÕES ENTRE CONCEITOS [Mapa de Revisão para Prova]">
        <outline text="CIA Triad é a base de TUDO — toda questão remete a C, I ou A"/>
        <outline text="Hashing e Assinaturas Digitais implementam o I (Integridade) do CIA Triad"/>
        <outline text="AAA implementa o C (Confidencialidade) via controle de acesso"/>
        <outline text="Controles de Segurança são as ferramentas práticas para proteger C, I e A"/>
        <outline text="Zero Trust é a evolução arquitetural moderna dos controles de acesso"/>
        <outline text="Gap Analysis mede o alinhamento dos seus controles com frameworks como NIST e ISO"/>
        <outline text="Segurança Física = camada mais externa da matriz de controles físicos"/>
        <outline text="Deception Technology combina controle Detetivo + Compensatório"/>
        <outline text="Certificados Digitais conectam AAA + Integridade + Criptografia"/>
        <outline text="MFA aparece em: CIA Triad (C) + AAA (Autenticação) + Zero Trust"/>
      </outline>

    </outline>
  </body>
</opml>

<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Security+ SY0-701 — 1.2 Change Management</title>
  </head>
  <body>
    <outline text="Change Management — Gerenciamento de Mudanças">

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="1. POR QUE EXISTE ⭐⭐">
        <outline text="Uma mudança em ambiente corporativo pode afetar milhares de sistemas"/>
        <outline text="Sistema não atualizado = sistema menos seguro ⭐"/>
        <outline text="Sem processo formal → inconsistências, falhas e instabilidade"/>
        <outline text="Objetivos">
          <outline text="Manter uptime e disponibilidade dos sistemas"/>
          <outline text="Garantir que todos estejam informados"/>
          <outline text="Evitar erros durante implementação"/>
          <outline text="Controlar frequência, tipo e escopo das mudanças"/>
        </outline>
      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="2. PROCESSO FORMAL DE CHANGE CONTROL ⭐⭐⭐ [MUITO COBRADO]">

        <outline text="Formulário de Change Control">
          <outline text="Razão da mudança"/>
          <outline text="Escopo — quantos e quais sistemas afetados"/>
          <outline text="Agendamento — data e hora exata"/>
          <outline text="Impacto esperado"/>
          <outline text="Análise de risco"/>
        </outline>

        <outline text="Change Control Board (CCB) ⭐">
          <outline text="Comitê central que aprova ou rejeita mudanças"/>
          <outline text="Analisa risco, escopo e timing"/>
          <outline text="Decisão final: aprovar ou negar"/>
          <outline text="Considera contexto — ex: empresas varejistas congelam mudanças entre Thanksgiving e Ano Novo"/>
        </outline>

        <outline text="Papéis no Processo">

          <outline text="Owner (Dono) ⭐">
            <outline text="Inicia o processo mas NÃO executa a mudança"/>
            <outline text="Gerencia e acompanha o processo"/>
            <outline text="Responsável por testar e validar após a mudança"/>
            <outline text="Exemplo: Depto. Envio e Recebimento solicita upgrade de impressoras"/>
          </outline>

          <outline text="Stakeholders ⭐">
            <outline text="Impactados pela mudança — nem sempre óbvios"/>
            <outline text="Devem ter input sobre processo e timing"/>
            <outline text="Exemplo — upgrade de software de etiquetas de envio">
              <outline text="Depto. Envio e Recebimento — usuário direto"/>
              <outline text="Contabilidade — usa relatórios de envio"/>
              <outline text="Prazos de entrega ao cliente"/>
              <outline text="Reconhecimento de receita"/>
              <outline text="CEO — visibilidade no resultado da empresa"/>
            </outline>
          </outline>

          <outline text="Equipe de TI">
            <outline text="Executa a mudança técnica"/>
            <outline text="Identifica stakeholders afetados"/>
            <outline text="Documenta todo o processo"/>
          </outline>

        </outline>

      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="3. ANÁLISE DE RISCO ⭐⭐">

        <outline text="Classificação: Alto / Médio / Baixo risco"/>

        <outline text="Riscos de FAZER a mudança">
          <outline text="Fix que não resolve o problema"/>
          <outline text="Mudança que quebra outro sistema"/>
          <outline text="Falha do sistema operacional após update"/>
          <outline text="Corrupção de dados"/>
        </outline>

        <outline text="Riscos de NÃO FAZER a mudança ⭐">
          <outline text="Vulnerabilidade exposta a atacantes"/>
          <outline text="Aplicação indisponível por falta de patch"/>
          <outline text="Outros serviços param de funcionar"/>
          <outline text="Sistema desatualizado = alvo fácil"/>
        </outline>

      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="4. SANDBOX — AMBIENTE DE TESTES ⭐⭐⭐ [COBRADO NA PROVA]">
        <outline text="Ambiente isolado para testes sem afetar produção"/>
        <outline text="Cópia idêntica ao ambiente de produção"/>
        <outline text="Permite testar upgrades, patches e mudanças com segurança"/>
        <outline text="Usado também para testar o Backout Plan"/>
        <outline text="Erros no sandbox não causam danos reais"/>
      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="5. BACKOUT PLAN — PLANO DE REVERSÃO ⭐⭐⭐ [MUITO COBRADO]">
        <outline text="Procedimento documentado para reverter mudança que deu errado"/>
        <outline text="SEMPRE fazer backup completo antes de qualquer mudança ⭐"/>
        <outline text="Deve ser testado no sandbox antes de produção"/>
        <outline text="Hierarquia de recuperação">
          <outline text="1. Executar o Backout Plan"/>
          <outline text="2. Se falhar → restaurar backup completo"/>
        </outline>
        <outline text="Tipos de reversão">
          <outline text="Simples — desinstalar patch e verificar arquivos originais"/>
          <outline text="Complexa — mudanças difíceis de reverter exigem técnicas específicas"/>
        </outline>
      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="6. JANELAS DE MANUTENÇÃO E AGENDAMENTO ⭐⭐">
        <outline text="Mudanças preferencialmente fora do horário de produção"/>
        <outline text="IT trabalha nos finais de semana, feriados e madrugadas"/>
        <outline text="Ambientes 24/7 — estratégia de failover ⭐">
          <outline text="Migra usuários para sistema secundário"/>
          <outline text="Atualiza sistema primário"/>
          <outline text="Se houver problema → reverte para secundário"/>
          <outline text="Processo preferencialmente automatizado"/>
        </outline>
        <outline text="Comunicação de downtime">
          <outline text="E-mails informando sobre janela de manutenção"/>
          <outline text="Calendário centralizado de change control"/>
        </outline>
      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="7. PERSPECTIVA DO TÉCNICO NA IMPLEMENTAÇÃO ⭐⭐">

        <outline text="Allow List vs Deny List ⭐⭐⭐ [MUITO COBRADO]">
          <outline text="Allow List — só roda o que está na lista, tudo mais bloqueado"/>
          <outline text="Deny List — tudo roda exceto o que está na lista"/>
          <outline text="Antivírus/Anti-malware = grande Deny List automatizada"/>
        </outline>

        <outline text="Escopo da Mudança">
          <outline text="Técnico só pode alterar o que está no documento de change control"/>
          <outline text="Exceção: mudanças secundárias necessárias para completar a primária"/>
          <outline text="Exemplo: upgrade de driver que exige modificar arquivo de configuração"/>
        </outline>

        <outline text="Reinicialização de Sistemas">
          <outline text="Reboot completo do sistema operacional"/>
          <outline text="Power cycle do dispositivo físico"/>
          <outline text="Stop/restart de serviço específico"/>
          <outline text="Solicitar que usuários fechem e reabram a aplicação"/>
        </outline>

        <outline text="Legacy Applications — Aplicações Legadas ⭐">
          <outline text="Rodando há anos sem suporte do desenvolvedor"/>
          <outline text="Alta resistência a mudanças — risco de quebrar algo"/>
          <outline text="Solução: documentar a aplicação para trazer ao ciclo normal de suporte"/>
          <outline text="Quem documenta vira o especialista da organização naquele sistema"/>
        </outline>

        <outline text="Dependências ⭐">
          <outline text="Mudança em um sistema pode exigir mudança em outro antes"/>
          <outline text="Dependências podem estar em sistemas diferentes"/>
          <outline text="Exemplo: atualizar software de gerenciamento de firewall exige atualizar os firewalls primeiro"/>
          <outline text="Complica o escopo original da mudança"/>
        </outline>

      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="8. DOCUMENTAÇÃO E CONTROLE DE VERSÃO ⭐⭐">
        <outline text="Documentação deve ser atualizada a cada mudança"/>
        <outline text="Inclui: diagramas de rede, IPs, configurações, processos"/>
        <outline text="Version Control — controle de versão ⭐">
          <outline text="Rastreia todas as mudanças entre ponto A e ponto B"/>
          <outline text="Permite reverter para versão anterior"/>
          <outline text="Exemplos: mudanças em configs de roteadores, patches de SO, registros"/>
          <outline text="Pode ser nativo da aplicação ou via ferramenta terceira"/>
        </outline>
        <outline text="Change Control é parte dos Procedimentos Operacionais Padrão (POPs)"/>
        <outline text="Ninguém deve alterar a rede sem aprovação formal"/>
      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="9. CONEXÕES COM OUTROS CONCEITOS DO SECURITY+">
        <outline text="CIA Triad — Disponibilidade: mudanças mal feitas causam downtime"/>
        <outline text="CIA Triad — Integridade: mudanças não documentadas corrompem o ambiente"/>
        <outline text="Controles Corretivos — Backout Plan é um controle corretivo"/>
        <outline text="Gap Analysis — identifica necessidade de mudanças"/>
        <outline text="Zero Trust — mudanças devem ser verificadas e autorizadas continuamente"/>
        <outline text="Sandbox — relacionado a ambientes de teste e segurança em camadas"/>
      </outline>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="10. PONTOS DE ATENÇÃO PARA A PROVA ⭐⭐⭐">
        <outline text="Change Control Board APROVA — não executa a mudança"/>
        <outline text="Owner SOLICITA — não executa a mudança"/>
        <outline text="TI EXECUTA — não aprova a mudança"/>
        <outline text="Sandbox ≠ Produção — nunca testar direto em produção"/>
        <outline text="Backout Plan DEVE ser testado ANTES da mudança ir para produção"/>
        <outline text="Allow List é mais restritivo que Deny List"/>
        <outline text="Sempre ter backup ANTES de qualquer mudança"/>
      </outline>

    </outline>
  </body>
</opml>

<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Security+ SY0-701 — 1.3 Criptografia e PKI</title>
  </head>
  <body>
    <outline text="Criptografia e PKI — Public Key Infrastructure">


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="1. FUNDAMENTOS DA CRIPTOGRAFIA">

        <outline text="Criptografia Simétrica ⭐⭐⭐">
          <outline text="Mesma chave para criptografar e descriptografar"/>
          <outline text="Também chamada de: chave secreta ou segredo compartilhado"/>
          <outline text="Analogia: mala presa por algemas ao entregador"/>
          <outline text="Vantagens">
            <outline text="Muito rápida"/>
            <outline text="Baixo custo computacional (overhead)"/>
          </outline>
          <outline text="Desvantagem">
            <outline text="Problema de escalabilidade — como distribuir a chave com segurança?"/>
          </outline>
        </outline>

        <outline text="Criptografia Assimétrica ⭐⭐⭐">
          <outline text="Duas chaves diferentes — matematicamente relacionadas"/>
          <outline text="Criadas ao mesmo tempo no mesmo processo"/>
          <outline text="Chave Privada — acessível apenas ao dono"/>
          <outline text="Chave Pública — pode ser vista e usada por qualquer pessoa"/>
          <outline text="Regra de ouro">
            <outline text="Chave PÚBLICA criptografa ➜ Chave PRIVADA descriptografa ⭐"/>
            <outline text="Chave PRIVADA assina ➜ Chave PÚBLICA verifica ⭐"/>
            <outline text="Impossível derivar a chave privada a partir da pública"/>
          </outline>
          <outline text="Geração de chaves — PGP / GPG">
            <outline text="Usa aleatorização e números primos muito grandes"/>
            <outline text="Distribui chave pública livremente"/>
            <outline text="Protege chave privada localmente com senha"/>
          </outline>
          <outline text="Exemplo — Alice e Bob">
            <outline text="1. Bob escreve mensagem em texto simples"/>
            <outline text="2. Bob criptografa com a chave PÚBLICA de Alice"/>
            <outline text="3. Resultado: texto cifrado (cipher text)"/>
            <outline text="4. Interceptadores não conseguem descriptografar"/>
            <outline text="5. Alice usa sua chave PRIVADA para descriptografar"/>
          </outline>
        </outline>

        <outline text="Comparativo Simétrica vs Assimétrica ⭐⭐">
          <outline text="Simétrica — rápida, mesma chave, problema de distribuição"/>
          <outline text="Assimétrica — lenta, duas chaves, resolve o problema de distribuição"/>
          <outline text="Uso combinado — assimétrica troca a chave, simétrica cifra os dados"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="2. TROCA DE CHAVES ⭐⭐⭐ [COBRADO NA PROVA]">

        <outline text="Out-of-Band (Fora da Rede)">
          <outline text="Troca física da chave — mensageiro, telefone, pessoalmente"/>
          <outline text="Analogia: pessoa com a mala atravessando o país"/>
          <outline text="Seguro mas não escalável para Internet"/>
        </outline>

        <outline text="In-Band (Pela Rede) ⭐">
          <outline text="Troca pela própria rede usando criptografia adicional"/>
          <outline text="Assimétrica criptografa a chave simétrica para envio seguro"/>
          <outline text="Chaves de Sessão (Session Keys)">
            <outline text="Temporárias e efêmeras — usadas uma vez e descartadas ⭐"/>
            <outline text="Cliente criptografa chave aleatória com chave pública do servidor"/>
            <outline text="Servidor descriptografa com sua chave privada"/>
            <outline text="Sessão encerrada → chave descartada → nova chave para próxima sessão"/>
          </outline>
        </outline>

        <outline text="Key Exchange Algorithm ⭐⭐">
          <outline text="Cria a mesma chave simétrica nos dois lados SEM enviar a chave pela rede"/>
          <outline text="Processo — Bob e Alice">
            <outline text="Bob combina sua chave PRIVADA com a chave PÚBLICA de Alice"/>
            <outline text="Alice combina sua chave PRIVADA com a chave PÚBLICA de Bob"/>
            <outline text="Resultado matemático: mesma chave simétrica nos dois lados"/>
          </outline>
          <outline text="Não é criptografia nem hashing — é construção de chave compartilhada"/>
          <outline text="Exemplo prático: Diffie-Hellman (DH), ECDH"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="3. HASHING ⭐⭐⭐ [MUITO COBRADO]">

        <outline text="Conceito">
          <outline text="Representa dados como uma string curta — message digest / impressão digital"/>
          <outline text="NÃO é criptografia — processo unidirecional e irreversível ⭐"/>
          <outline text="Pequena alteração na entrada = hash completamente diferente ⭐"/>
        </outline>

        <outline text="Algoritmos">
          <outline text="SHA-256 — produz 256 bits representados em 64 caracteres hexadecimais ⭐"/>
          <outline text="MD5 — OBSOLETO, vulnerável a colisões desde 1996 ⭐ NÃO USAR"/>
        </outline>

        <outline text="Colisões ⭐">
          <outline text="Quando duas entradas diferentes geram o mesmo hash"/>
          <outline text="Deve ser extremamente raro em algoritmos seguros"/>
          <outline text="MD5 é vulnerável a colisões — razão para não usar"/>
        </outline>

        <outline text="Usos Práticos">
          <outline text="Verificar integridade de arquivos baixados — comparar hash do site com hash local"/>
          <outline text="Armazenamento seguro de senhas"/>
          <outline text="Criação de assinaturas digitais"/>
        </outline>

        <outline text="Salt — Fortalecimento de Senhas ⭐⭐">
          <outline text="Adiciona dados aleatórios ao hash da senha antes de armazenar"/>
          <outline text="Cada usuário recebe um salt diferente"/>
          <outline text="Mesma senha → hashes diferentes para cada usuário"/>
          <outline text="Impede uso de Rainbow Tables (tabelas precomputadas de hashes) ⭐"/>
        </outline>

        <outline text="Key Stretching ⭐">
          <outline text="Técnica para fortalecer chaves fracas"/>
          <outline text="Realiza hashing múltiplas vezes (ex: hashing de senha várias vezes)"/>
          <outline text="Aumenta o tempo necessário para ataque de força bruta"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="4. ASSINATURAS DIGITAIS ⭐⭐⭐ [MUITO COBRADO]">

        <outline text="Garante: Integridade + Autenticidade + Não-Repúdio ⭐"/>

        <outline text="Processo de Criação — Alice">
          <outline text="1. Cria o documento"/>
          <outline text="2. Gera o hash do documento"/>
          <outline text="3. Criptografa o hash com sua chave PRIVADA → cria a assinatura"/>
          <outline text="4. Envia: documento + assinatura digital"/>
        </outline>

        <outline text="Processo de Verificação — Bob">
          <outline text="1. Recebe documento + assinatura"/>
          <outline text="2. Gera hash do documento recebido"/>
          <outline text="3. Descriptografa a assinatura com a chave PÚBLICA de Alice"/>
          <outline text="4. Compara os dois hashes"/>
          <outline text="5. Hashes iguais → integridade e autenticidade confirmadas ✅"/>
        </outline>

        <outline text="Ponto de atenção para a prova ⭐">
          <outline text="Chave PRIVADA assina — chave PÚBLICA verifica"/>
          <outline text="Nunca inverter essa ordem!"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="5. CRIPTOGRAFIA DE DADOS ⭐⭐⭐">

        <outline text="Dados em Repouso (At Rest)">
          <outline text="Criptografia de Disco Inteiro">
            <outline text="BitLocker — Windows ⭐"/>
            <outline text="FileVault — macOS ⭐"/>
          </outline>
          <outline text="Criptografia de Arquivo Individual">
            <outline text="EFS (Encrypting File System) — Windows / NTFS"/>
          </outline>
        </outline>

        <outline text="Dados em Banco de Dados">
          <outline text="Criptografia Transparente — chave simétrica cifra tudo no banco"/>
          <outline text="Criptografia em Nível de Coluna — cifra apenas dados sensíveis (ex: SSN) ⭐"/>
        </outline>

        <outline text="Dados em Trânsito (In Transit) ⭐⭐">
          <outline text="HTTPS — comunicações via navegador"/>
          <outline text="VPN — túnel criptografado">
            <outline text="SSL/TLS — VPN baseada em cliente ⭐"/>
            <outline text="IPsec — VPN site-to-site ⭐"/>
          </outline>
        </outline>

        <outline text="Algoritmos de Criptografia ⭐⭐">
          <outline text="Ambos os lados devem usar os mesmos algoritmos"/>
          <outline text="DES — padrão antigo, OBSOLETO"/>
          <outline text="AES — padrão moderno, seguro e rápido ⭐"/>
        </outline>

        <outline text="Tamanho das Chaves ⭐">
          <outline text="Chaves maiores = mais resistência a força bruta"/>
          <outline text="Simétricas — 128 bits ou mais (padrão atual seguro)"/>
          <outline text="Assimétricas — 3072 bits ou mais"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="6. HARDWARE DE CRIPTOGRAFIA ⭐⭐">

        <outline text="TPM — Trusted Platform Module ⭐⭐">
          <outline text="Chip na placa-mãe para funções criptográficas"/>
          <outline text="Geração de números aleatórios e chaves criptográficas"/>
          <outline text="Memória persistente — armazena chaves únicas da máquina"/>
          <outline text="Usado pelo BitLocker para criptografia de disco completo"/>
          <outline text="Protegido por senha — imune a força bruta"/>
          <outline text="Escopo: um único dispositivo"/>
        </outline>

        <outline text="HSM — Hardware Security Module ⭐⭐">
          <outline text="Funções criptográficas em escala para data centers"/>
          <outline text="Geralmente clusterizado para redundância"/>
          <outline text="Centraliza chaves de centenas de servidores web"/>
          <outline text="Usa aceleradores criptográficos para criptografia em tempo real"/>
          <outline text="Escopo: toda a infraestrutura"/>
        </outline>

        <outline text="Secure Enclave ⭐">
          <outline text="Processador de segurança separado da CPU principal"/>
          <outline text="Presente em celulares e laptops modernos"/>
          <outline text="Gerencia processo de boot (boot ROM)"/>
          <outline text="Gerador de números aleatórios verdadeiros"/>
          <outline text="Criptografia AES em tempo real dos dados na memória"/>
          <outline text="Raiz de Confiança — chaves embutidas imutáveis"/>
        </outline>

        <outline text="KMS — Key Management System ⭐⭐">
          <outline text="Gerenciamento centralizado de todas as chaves"/>
          <outline text="Gerencia: SSL/TLS, SSH, BitLocker e outras"/>
          <outline text="On-premises ou baseado na nuvem"/>
          <outline text="Funcionalidades">
            <outline text="Rotação automática de chaves"/>
            <outline text="Gerenciamento de certificados"/>
            <outline text="Separação das chaves dos dados protegidos"/>
            <outline text="Painel de visualização de chaves ativas"/>
          </outline>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="7. PKI — PUBLIC KEY INFRASTRUCTURE ⭐⭐⭐ [MUITO COBRADO]">

        <outline text="Definição">
          <outline text="Conjunto de políticas, procedimentos, hardware e software"/>
          <outline text="Gerencia criação, distribuição, armazenamento e revogação de certificados digitais"/>
          <outline text="Associa certificados a pessoas ou dispositivos"/>
        </outline>

        <outline text="Certificado Digital ⭐⭐⭐">
          <outline text="Arquivo que contém chave pública + assinatura digital"/>
          <outline text="Versão digital de um cartão de identificação"/>
          <outline text="Padrão: formato X.509 ⭐"/>
          <outline text="Contém: número de série, versão, algoritmo, emissor, dono, chave pública"/>
          <outline text="Wildcard Certificate — usa asterisco (*) para cobrir subdomínios ⭐"/>
          <outline text="SAN — Subject Alternative Name — múltiplos domínios em um certificado"/>
        </outline>

        <outline text="CA — Autoridade Certificadora ⭐⭐⭐">
          <outline text="Terceiro confiável que assina digitalmente certificados"/>
          <outline text="Navegadores confiam nas CAs — base da confiança na web"/>
          <outline text="Verifica identidade antes de emitir o certificado"/>
          <outline text="CA Interna — para sistemas internos da organização ⭐">
            <outline text="Instala software de CA na organização"/>
            <outline text="Certificado público da CA instalado em todos os computadores internos"/>
          </outline>
        </outline>

        <outline text="CSR — Certificate Signing Request ⭐⭐">
          <outline text="Solicitação de assinatura de certificado enviada à CA"/>
          <outline text="Contém: chave pública + informações de identificação"/>
          <outline text="CA valida e assina com sua chave privada"/>
          <outline text="CA devolve o certificado assinado"/>
        </outline>

        <outline text="Raiz de Confiança (Root of Trust) ⭐">
          <outline text="Base de toda a cadeia de confiança"/>
          <outline text="Pode ser hardware, software ou firmware"/>
          <outline text="Ex: Secure Enclave, TPM, CA Raiz"/>
        </outline>

        <outline text="Web of Trust — Rede de Confiança">
          <outline text="Alternativa à CA centralizada"/>
          <outline text="Vários indivíduos assinam certificados uns dos outros"/>
          <outline text="Modelo descentralizado de confiança"/>
        </outline>

        <outline text="Revogação de Certificados ⭐⭐">
          <outline text="CRL — Certificate Revocation List ⭐">
            <outline text="Lista de todos os certificados revogados"/>
            <outline text="Mantida pela própria CA"/>
          </outline>
          <outline text="OCSP — Online Certificate Status Protocol ⭐">
            <outline text="Mais eficiente que CRL"/>
            <outline text="Verifica status do certificado em tempo real"/>
          </outline>
          <outline text="OCSP Stapling ⭐">
            <outline text="Status do certificado embutido no próprio servidor web"/>
            <outline text="Enviado durante o handshake SSL"/>
            <outline text="Elimina consulta separada à CA"/>
          </outline>
        </outline>

        <outline text="Key Escrow — Custódia de Chaves ⭐">
          <outline text="Terceiro ou a própria organização guarda cópia das chaves"/>
          <outline text="Permite acesso se funcionário sair ou agência governamental solicitar"/>
          <outline text="Controverso mas necessário em alguns ambientes"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="8. OFUSCAÇÃO E PROTEÇÃO DE DADOS ⭐⭐">

        <outline text="Ofuscação — Conceito Geral">
          <outline text="Tornar informação difícil de compreender"/>
          <outline text="Reversível apenas por quem conhece o método"/>
        </outline>

        <outline text="Esteganografia ⭐⭐">
          <outline text="Esconde dados dentro de outro arquivo (imagem, áudio, vídeo)"/>
          <outline text="Cover text — documento que contém os dados ocultos"/>
          <outline text="Segurança por obscuridade — NÃO é segurança real sozinha ⭐"/>
          <outline text="Exemplo: yellow dots em impressoras — códigos de identificação de máquina"/>
        </outline>

        <outline text="Tokenização ⭐⭐">
          <outline text="Substitui dado sensível por um token (substituto não sensível)"/>
          <outline text="Token NÃO tem relação matemática com o dado original ⭐"/>
          <outline text="Token de uso único — não pode ser reutilizado"/>
          <outline text="Uso em pagamentos móveis — smartwatches e celulares"/>
          <outline text="Servidor de tokens realiza a troca e validação"/>
          <outline text="Vantagem: não precisa criptografar dados em trânsito"/>
        </outline>

        <outline text="Mascaramento de Dados ⭐">
          <outline text="Esconde partes de dados sensíveis"/>
          <outline text="Exemplo: mostrar apenas últimos 4 dígitos do cartão de crédito"/>
          <outline text="Protege PII — Informações Pessoais Identificáveis"/>
          <outline text="Usado por atendentes de suporte ao cliente"/>
        </outline>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="9. BLOCKCHAIN ⭐⭐">

        <outline text="Definição: livro-razão distribuído (distributed ledger)"/>
        <outline text="Registro público e transparente de transações"/>
        <outline text="Todos os participantes mantêm uma cópia"/>

        <outline text="Aplicações">
          <outline text="Processamento de pagamentos (Bitcoin)"/>
          <outline text="Identificação digital"/>
          <outline text="Monitoramento de cadeia de suprimentos"/>
          <outline text="Votação digital"/>
        </outline>

        <outline text="Processo ⭐">
          <outline text="1. Transação criada (ex: transferência de Bitcoin)"/>
          <outline text="2. Distribuída para todos os participantes"/>
          <outline text="3. Agrupada em bloco + hash do bloco (integridade) ⭐"/>
          <outline text="4. Qualquer modificação invalida o hash"/>
          <outline text="5. Outros nós detectam hash inválido e rejeitam o bloco"/>
        </outline>

        <outline text="Conexão com Hashing — integridade garantida pelo hash de cada bloco ⭐"/>

      </outline>


      <!-- ═══════════════════════════════════════════════════════════ -->
      <outline text="10. PONTOS CRÍTICOS PARA A PROVA ⭐⭐⭐">

        <outline text="Hashing NÃO é criptografia — irreversível ⭐"/>
        <outline text="MD5 — OBSOLETO e vulnerável a colisões ⭐"/>
        <outline text="SHA-256 — algoritmo moderno e seguro ⭐"/>
        <outline text="Chave PRIVADA assina / Chave PÚBLICA verifica ⭐"/>
        <outline text="Chave PÚBLICA criptografa / Chave PRIVADA descriptografa ⭐"/>
        <outline text="Salt impede Rainbow Tables ⭐"/>
        <outline text="Session Keys são efêmeras — descartadas após uso ⭐"/>
        <outline text="TPM = um dispositivo / HSM = toda a infraestrutura ⭐"/>
        <outline text="OCSP Stapling = mais eficiente que CRL ⭐"/>
        <outline text="Tokenização ≠ Criptografia — sem relação matemática com dado original ⭐"/>
        <outline text="Esteganografia sozinha NÃO é segurança real ⭐"/>
        <outline text="AES = padrão moderno / DES = obsoleto ⭐"/>
        <outline text="Blockchain usa hashing para garantir integridade dos blocos ⭐"/>

      </outline>


    </outline>
  </body>
</opml>
